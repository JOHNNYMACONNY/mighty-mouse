diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..82b782a
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,55 @@
+name: CI
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+
+permissions:
+  contents: read
+
+jobs:
+  test:
+    runs-on: ubuntu-latest
+    strategy:
+      fail-fast: false
+      matrix:
+        python-version: ["3.10", "3.11", "3.12", "3.13"]
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: ${{ matrix.python-version }}
+          cache: pip
+      - name: Install both distributions and test dependencies
+        run: python -m pip install -e '.[dev]' -e ./mcp
+      - name: Run complete test suite
+        run: python -m pytest
+
+  package:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: "3.13"
+      - name: Build both wheels
+        run: |
+          python -m pip install build
+          python -m build --wheel --outdir dist .
+          python -m build --wheel --outdir dist ./mcp
+      - name: Install only built wheels in a clean environment
+        run: |
+          python -m venv /tmp/mighty-mouse-wheel-venv
+          /tmp/mighty-mouse-wheel-venv/bin/python -m pip install dist/mighty_mouse-*.whl dist/mighty_mouse_mcp-*.whl
+      - name: Smoke test installed wheels outside checkout
+        working-directory: /tmp
+        run: |
+          PY=/tmp/mighty-mouse-wheel-venv/bin/python
+          CLI=/tmp/mighty-mouse-wheel-venv/bin/mighty-mouse
+          "$PY" -c "import mighty_mouse; assert mighty_mouse.__version__ == '0.2.0'"
+          "$PY" -c "import mighty_mouse_mcp.server"
+          "$CLI" --help
+          "$CLI" protocol "CI packaging smoke" --json | "$PY" -c "import json,sys; d=json.load(sys.stdin); assert d['interface']=='protocol' and d['schema_version']==1"
+          mkdir -p /tmp/mighty-mouse-verify-smoke
+          "$CLI" verify /tmp/mighty-mouse-verify-smoke --test-command "$PY -c 'print(\"wheel smoke passed\")'" --json | "$PY" -c "import json,sys; d=json.load(sys.stdin); assert d['interface']=='verify' and d['passed'] is True"
