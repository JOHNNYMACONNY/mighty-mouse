new file mode 100644
index 0000000..12f6ad9
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,64 @@
+name: CI
+
+on:
+  push:
+    branches:
+      - main
+  pull_request:
+
+permissions:
+  contents: read
+
+jobs:
+  test:
+    name: Test Python ${{ matrix.python-version }}
+    runs-on: ubuntu-latest
+    strategy:
+      fail-fast: false
+      matrix:
+        python-version:
+          - "3.10"
+          - "3.11"
+          - "3.12"
+          - "3.13"
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: ${{ matrix.python-version }}
+          cache: pip
+      - name: Install both distributions
+        run: |
+          python -m pip install --upgrade pip
+          python -m pip install -e ".[dev]"
+          python -m pip install -e ./mcp
+      - name: Run complete test suite
+        run: python -m pytest -q
+
+  package:
+    name: Build and smoke-test wheels
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: "3.13"
+          cache: pip
+      - name: Install build frontend
+        run: python -m pip install build
+      - name: Build both wheels
+        run: |
+          python -m build --wheel --outdir dist/core .
+          python -m build --wheel --outdir dist/mcp ./mcp
+      - name: Install only built wheels in a clean environment
+        run: |
+          python -m venv "$RUNNER_TEMP/wheel-smoke"
+          "$RUNNER_TEMP/wheel-smoke/bin/python" -m pip install dist/core/*.whl dist/mcp/*.whl
+      - name: Smoke-test installed wheels outside checkout
+        run: |
+          cd "$RUNNER_TEMP"
+          "$RUNNER_TEMP/wheel-smoke/bin/python" -c "import mighty_mouse; print(mighty_mouse.__version__)"
+          "$RUNNER_TEMP/wheel-smoke/bin/python" -c "import mighty_mouse_mcp.server"
+          "$RUNNER_TEMP/wheel-smoke/bin/mighty-mouse" --help
+          "$RUNNER_TEMP/wheel-smoke/bin/mighty-mouse" protocol --complexity medium --json "CI packaging smoke"
+          "$RUNNER_TEMP/wheel-smoke/bin/mighty-mouse" verify "$RUNNER_TEMP" --json --test-command "$RUNNER_TEMP/wheel-smoke/bin/python -c 'print(\"ok\")'"
